# zerobot settings (YAML)
# 仅作为示例，可按需裁剪。

llm:
  default_provider: openai
  default_model: qwen3-coder-plus
  openai:
    base_url: "http://localhost:8317"
    api_key: "sk-xxxx"
    model: qwen3-coder-plus
    headers: {}
  anthropic:
    base_url: "http://localhost:8317"
    api_key: "sk-xxxx"
    model: qwen3-coder-plus
    headers: {}

permissions:
  # 规则格式：tool(pattern)
  # tool 为 read/write/edit/bash/grep/glob/find/delete 等
  # pattern 支持 glob，如 **/*.rs 或 /tmp/**
  allow:
    - read(**)
    - glob(**)
    - find(**)
    - grep(**)
    - write(./data/**)
    - edit(./data/**)
  deny:
    - delete(**)
  ask:
    - bash(*)

env:
  # 传递给工具运行时的环境变量
  ZEROBOT_SAMPLE: "1"

# 插件与 MCP
enabled_plugins: []
allowed_mcp_servers: []
denied_mcp_servers: []

# HTTP hooks
allowed_http_hook_urls: []
http_hook_allowed_env_vars: []

# 其他可选字段
cleanup_period_days: 30
model: null
available_models: []
model_overrides: {}
output_style: null
respect_gitignore: true

# 高级字段（占位）
api_key_helper: null
otel_headers_helper: null
hooks: []
disable_all_hooks: false
allow_managed_hooks_only: false
allow_managed_permission_rules_only: false
allow_managed_mcp_servers_only: false
status_line: null
file_suggestion: null
attribution: null
include_git_instructions: false
include_co_authored_by: false
